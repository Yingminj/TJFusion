# Keep the build context small. Several images build from the repo root to reach
# the shared protocol/ package (RealSense, FFS-depth, Sam3, Siglip, FlowPose).
# Only exclude sibling Docker projects that are NOT built from the repo root.
.git
**/__pycache__
**/*.pyc

# Unrelated Docker projects (not built from the repo root)
MarvinDocker
FusionDocker
YOLODocker
SenyunDocker

# Heavy / non-build artifacts
**/logs
**/output
*.pth
*.onnx
*.engine
